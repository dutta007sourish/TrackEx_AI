<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Flap / card behind wallet (lighter green, peeking top-left) -->
    <path android:pathData="M34,34 L70,34 Q74,34 74,38 L74,48 L30,48 L30,38 Q30,34 34,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="30"
                android:startY="34"
                android:endX="74"
                android:endY="48">
                <item android:color="#66BB6A" android:offset="0.0" />
                <item android:color="#43A047" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main wallet body -->
    <path android:pathData="M32,42 L76,42 Q80,42 80,46 L80,76 Q80,80 76,80 L32,80 Q28,80 28,76 L28,46 Q28,42 32,42 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="42"
                android:endX="80"
                android:endY="80">
                <item android:color="#4CAF50" android:offset="0.0" />
                <item android:color="#2E7D32" android:offset="0.5" />
                <item android:color="#1B5E20" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Clasp bump (orange/yellow) -->
    <path android:pathData="M66,55 L80,55 L80,67 L66,67 Q62,67 62,63 L62,59 Q62,55 66,55 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="62"
                android:startY="55"
                android:endX="80"
                android:endY="67">
                <item android:color="#FFC107" android:offset="0.0" />
                <item android:color="#FF9800" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Clasp dot (white) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M70,61 m-3,0 a3,3 0,1 1,6 0 a3,3 0,1 1,-6 0" />

</vector>